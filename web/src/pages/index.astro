---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import Problema from '../components/Problema.astro';
import Solucao from '../components/Solucao.astro';
import Cta from '../components/Cta.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="NutriScan — Conheça o que você consome">
  <NavBar />
  <Hero />
  <Problema />
  <Solucao />
  <Cta />
  <Footer />
  <div class="mobile-download-bar" id="mobile-download-bar">
    <div class="mobile-download-bar-inner">
      <img src="/logo.png" alt="NutriScan" width="28" height="28" class="mobile-download-bar-icon" />
      <div class="mobile-download-bar-text">
        <span class="mobile-download-bar-title">NutriScan</span>
        <span class="mobile-download-bar-sub">Gratuito &middot; Sem cadastro</span>
      </div>
      <a href="/downloads/nutriscan.apk" download class="mobile-download-bar-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Baixar
      </a>
    </div>
  </div>
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  const hamburger = document.getElementById('nav-hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('active');
    mobileMenu?.classList.toggle('open');
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('active');
      mobileMenu?.classList.remove('open');
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) {
      hamburger?.classList.remove('active');
      mobileMenu?.classList.remove('open');
    }
  });

  const downloadBar = document.getElementById('mobile-download-bar');
  const ctaSection = document.getElementById('cta');
  let ctaIsIntersecting = false;

  if (downloadBar && ctaSection) {
    const barObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          ctaIsIntersecting = entry.isIntersecting;
        });
      },
      { threshold: 0.3 }
    );
    barObserver.observe(ctaSection);

    function updateDownloadBar() {
      if (ctaIsIntersecting) {
        downloadBar.classList.remove('show');
        return;
      }
      const currentScroll = window.scrollY;
      if (currentScroll > 300) {
        downloadBar.classList.add('show');
      } else {
        downloadBar.classList.remove('show');
      }
    }

    window.addEventListener('scroll', updateDownloadBar, { passive: true });
    updateDownloadBar();
  }
</script>

<style>
  .mobile-download-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid var(--green-100);
    padding: 10px 16px;
    padding-bottom: calc(10px + env(safe-area-inset-bottom, 0px));
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: block;
  }

  .mobile-download-bar.show {
    transform: translateY(0);
  }

  .mobile-download-bar-inner {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 480px;
    margin: 0 auto;
  }

  .mobile-download-bar-icon {
    border-radius: 12px;
    flex-shrink: 0;
  }

  .mobile-download-bar-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }

  .mobile-download-bar-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--green-800);
    line-height: 1.2;
  }

  .mobile-download-bar-sub {
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.3;
  }

  .mobile-download-bar-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--green-700);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 700;
    padding: 10px 18px;
    border-radius: 100px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .mobile-download-bar-btn:hover {
    background: var(--green-800);
  }

  @media (min-width: 769px) {
    .mobile-download-bar {
      display: none !important;
    }
  }
</style>
