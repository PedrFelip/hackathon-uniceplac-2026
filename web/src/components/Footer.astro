---
import Container from './Container.astro';
---

<footer>
  <Container>
    <div class="footer-inner">
      <div class="footer-left">
        <a href="#" class="footer-brand">
          <img src="/logo.png" alt="" width="20" height="20" />
          <span>NutriScan</span>
        </a>
        <span class="footer-dot">&middot;</span>
        <span class="footer-meta">Hackathon UNICEPLAC 2026</span>
      </div>
      <a
        href="https://github.com/PedrFelip/hackaton-uniceplac-2026"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-github"
        aria-label="GitHub"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
          ></path>
        </svg>
      </a>
    </div>
  </Container>
</footer>

<style>
  footer {
    padding: 32px 0;
    border-top: 1px solid var(--green-100);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--green-700);
    text-decoration: none;
  }

  .footer-brand img {
    border-radius: 8px;
  }

  .footer-dot {
    color: var(--green-200);
    font-size: 0.8rem;
  }

  .footer-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer-github {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: var(--text-muted);
    transition: all 0.3s ease;
  }

  .footer-github:hover {
    color: var(--green-700);
    background: var(--green-50);
  }

  @media (min-width: 1440px) {
    .container {
      max-width: 1240px;
    }
  }

  @media (max-width: 768px) {
    footer {
      padding: 24px 0;
      padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
    }

    .footer-inner {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }

    .footer-left {
      flex-direction: column;
      gap: 4px;
    }

    .footer-dot {
      display: none;
    }

    .container {
      padding: 0 20px;
    }

    .footer-brand {
      font-size: 0.9rem;
    }
  }
</style>
