---
import BackgroundEffects from './BackgroundEffects.astro';
import Container from './Container.astro';
import Button from './Button.astro';
---

<section class="cta" id="cta">
  <div class="cta-bg">
    <BackgroundEffects variant="rings" opacity="0.2" />
  </div>
  <Container>
    <div class="cta-inner reveal">
      <div class="cta-leaf">
        <svg width="120" height="120" viewBox="0 0 120 120" fill="none">
          <path
            d="M60 8C36 36 20 56 28 80C32 92 44 100 60 112C76 100 88 92 92 80C100 56 84 36 60 8Z"
            fill="var(--green-800)"
            opacity="0.15"></path>
        </svg>
      </div>
      <h2>Comece a escanear<br /><em>hoje mesmo</em></h2>
      <p>
        NutriScan é gratuito e de código aberto.<br />
        Baixe e comece a fazer escolhas melhores no supermercado.
      </p>
      <Button
        href="/downloads/nutriscan.apk"
        variant="accent"
        size="large"
        download
        id="download-btn"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="margin-right:8px"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Baixar o app
      </Button>
      <p class="cta-note">Android 8.1+ &middot; Sem cadastro necessário</p>
    </div>
  </Container>
</section>

<style>
  .cta {
    position: relative;
    padding: 120px 0;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(170deg, var(--green-800), var(--green-950));
    overflow: hidden;
  }

  .cta-inner {
    position: relative;
    text-align: center;
    z-index: 2;
  }

  .cta-leaf {
    position: absolute;
    top: -30px;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .cta h2 {
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    color: var(--cream);
    margin: 0 0 20px;
    position: relative;
  }

  .cta h2 em {
    font-style: italic;
    color: var(--green-300);
  }

  .cta p {
    font-size: 1.1rem;
    color: rgba(248, 245, 239, 0.6);
    margin: 0 0 40px;
    line-height: 1.8;
  }

  .cta-note {
    margin-top: 16px !important;
    font-size: 0.85rem !important;
    color: rgba(248, 245, 239, 0.35) !important;
  }

  @media (max-width: 768px) {
    .cta {
      padding: 72px 0;
    }

    .cta h2 {
      font-size: clamp(1.5rem, 5vw, 2.2rem);
      margin-bottom: 14px;
    }

    .cta p {
      font-size: 0.92rem;
      margin-bottom: 28px;
      line-height: 1.7;
    }

    .cta-note {
      font-size: 0.8rem !important;
    }
  }
</style>
