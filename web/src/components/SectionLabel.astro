---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="section-label reveal">
  <span class="label-line"></span>
  <span>{text}</span>
</div>

<style>
  .section-label {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--green-500);
    margin-bottom: 24px;
  }

  .label-line {
    display: inline-block;
    width: 40px;
    height: 1.5px;
    background: var(--green-400);
    border-radius: 1px;
  }
</style>
