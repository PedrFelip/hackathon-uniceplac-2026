---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={['container', className]}>
  <slot />
</div>

<style>
  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
  }

  @media (min-width: 1440px) {
    .container {
      max-width: 1240px;
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 20px;
    }
  }

  @media (max-width: 480px) {
    .container {
      padding: 0 16px;
    }
  }
</style>
