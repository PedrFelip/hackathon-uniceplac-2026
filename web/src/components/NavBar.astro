---
const links = [
  { href: '#problema', label: 'O Problema' },
  { href: '#solucao', label: 'A Solução' },
  { href: '#cta', label: 'Baixar' },
];
---

<nav>
  <div class="nav-inner">
    <a href="#" class="logo">
      <img src="/logo.png" alt="NutriScan" width="32" height="32" />
      <span>NutriScan</span>
    </a>
    <div class="nav-links">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  <div class="mobile-menu" id="mobile-menu">
    {
      links.map((link) => (
        <a href={link.href} class="mobile-menu-link">
          {link.label}
        </a>
      ))
    }
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    background: rgba(248, 245, 239, 0.75);
    border-bottom: 1px solid rgba(169, 188, 142, 0.15);
  }

  .nav-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--green-800);
  }

  .nav-links {
    display: flex;
    gap: 32px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .nav-links a {
    transition: color 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--green-600);
  }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 110;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--green-800);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .nav-hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .nav-hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .nav-hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 0 24px 20px;
    gap: 0;
  }

  .mobile-menu.open {
    display: flex;
    animation: fadeDown 0.3s ease forwards;
  }

  .mobile-menu-link {
    padding: 14px 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--green-700);
    border-bottom: 1px solid var(--green-100);
    transition: color 0.2s ease;
  }

  .mobile-menu-link:last-child {
    border-bottom: none;
  }

  .mobile-menu-link:hover {
    color: var(--green-500);
  }

  @media (max-width: 1024px) {
    .nav-inner {
      padding: 14px 20px;
    }

    .nav-links {
      gap: 24px;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .nav-links {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }
  }
</style>
